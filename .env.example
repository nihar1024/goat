########################################################################
# ------------ MANDATORY (CHANGE ACCORDING TO YOUR SETUP) ------------#
########################################################################
# Since .env is gitignored, you can use .env.example to build a new `
# .env` file when you clone the repo. This file will be committed
# to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env`
# and populate it with your secrets.
########################################################################

############
#  BASICS  #
############
ENVIRONMENT=dev
ASSETS_URL=https://assets.plan4better.de
# Public URL of the web app. Used by the backend to build links in emails
# (e.g. organization invitations). Must be the real domain in deployments.
CLIENT_URL=http://localhost:3000
# Single auth switch for all services and the web app.
# False = no Keycloak; requests act as the seeded default admin identity.
AUTH=False

############
#  DB      #
############
POSTGRES_SERVER=db
POSTGRES_USER=rds
POSTGRES_PASSWORD=database_password
POSTGRES_PORT=5432
POSTGRES_DB=goat

############
#  WEB     #
############
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_GEOAPI_URL=http://127.0.0.1:8100
NEXT_PUBLIC_PROCESSES_URL=http://127.0.0.1:8300
# @see: https://next-auth.js.org/providers/keycloak
# NEXTAUTH_URL is the app's public URL; NEXT_PUBLIC_APP_URL is derived from it.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=secret
# The web app's Keycloak issuer and client id are derived from the
# Keycloak section below (KEYCLOAK_SERVER_URL + REALM_NAME, KEYCLOAK_CLIENT_ID).

############
#  S3      #
############
AWS_S3_ASSETS_BUCKET=plan4better-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=goat
S3_ENDPOINT_URL=http://minio:9000
# Only needed for local dev: browser needs localhost, but Docker services use minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_PATH=""
S3_PROVIDER=minio
S3_FORCE_PATH_STYLE=True

############
#  Core    #
############
DATA_DIR=/app/data

############
#  Windmill #
############
WINDMILL_URL=http://windmill-server:8000
WINDMILL_WORKSPACE=goat
WINDMILL_TOKEN=
# Print worker URL (for rendering report pages via Playwright)
PRINT_BASE_URL=http://goat-dev:3000

############
#  Keycloak #
############
KEYCLOAK_SERVER_URL=
REALM_NAME=
# Single client for web login, core admin enrichment and the print worker.
# Leave unset when AUTH=False.
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# Default identity when AUTH=False (dev / self-hosted without Keycloak);
# user + organization are seeded by initial_data
DEFAULT_USER_ID=744e4fd1-685c-495c-8b02-efebce875359
DEFAULT_USER_EMAIL=admin@goat.local
DEFAULT_USER_FIRSTNAME=GOAT
DEFAULT_USER_LASTNAME=Admin
DEFAULT_ORGANIZATION_NAME=GOAT
# Plan/quotas for organizations when no billing is configured (self-hosted)
DEFAULT_PLAN_NAME=goat_enterprise
DEFAULT_QUOTA_STORAGE_MB=1048576
DEFAULT_QUOTA_PROJECTS=10000
DEFAULT_QUOTA_EDITORS=1000
DEFAULT_QUOTA_VIEWERS=1000

############
#  Billing / email (optional) #
############
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_NAME=Plan4Better - Account
