      }
    },
    {
      "label": "core-pre-launch",
      "dependsOn": ["kill-port-8000", "uv-sync"],
      "dependsOrder": "sequence"
    },
    {
      "label": "geoapi-pre-launch",
      "dependsOn": ["kill-port-8100", "uv-sync"],
      "dependsOrder": "sequence"
    },
    {
      "label": "processes-pre-launch",
      "dependsOn": ["kill-port-8300", "uv-sync"],
      "dependsOrder": "sequence"
    },
    {
      "label": "accounts-pre-launch",
