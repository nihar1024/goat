{
  "eslint.workingDirectories": [
    {
      "pattern": "apps/*/"
    },
    {
      "pattern": "packages/js/*/"
    }
  ],
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "workbench.editor.showTabs": "multiple",
  "i18n-ally.localesPaths": [
    "apps/web/i18n/locales",
  ],
  "i18n-ally.enabledFrameworks": [
    "react",
    "i18next",
    "react-i18next"
  ],
  "i18n-ally.sortKeys": true,
  "i18n-ally.keepFulfilled": true,
  "i18n-ally.namespace": true,
  "i18n-ally.keystyle": "nested",
  "editor.formatOnSave": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "githubPullRequests.experimental.chat": true,
  "githubPullRequests.experimental.notificationsView": true,
  "python.defaultInterpreterPath": ".venv/bin/python",
  // Pylance type-checking is left off: mypy (configured below + in pyproject) is
  // the Python type gate. Pylance's "basic" default floods SQLModel/SQLAlchemy
  // code with false positives; "off" keeps imports, syntax, autocomplete and
  // navigation while leaving type checking to mypy.
  "python.analysis.typeCheckingMode": "off",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "--import-mode=importlib",
    "-p",
    "no:cacheprovider",
    "packages/python/goatlib/tests",
    "apps/geoapi/tests",
    "apps/processes/tests",
    "apps/core/tests",
  ],
  "python.testing.cwd": "${workspaceFolder}",
  // Vitest testing for web app
  "vitest.enable": true,
  "vitest.commandLine": "pnpm --filter @p4b/web test",
  "testExplorer.useNativeTesting": true,
  "mypy-type-checker.ignorePatterns": [
    ".direnv/*",
    "docs/*",
    "*generated/*",
    "*cache*",
    "dist*",
    "alembic"
  ],
  "mypy-type-checker.importStrategy": "fromEnvironment",
  "mypy-type-checker.reportingScope": "workspace",
  "mypy-type-checker.preferDaemon": false,
  // Disable automatic venv activation in terminals (breaks frontend dev server)
  "python.terminal.activateEnvironment": false,
  // "Launch App" runs each service inside a tmux session so it survives
  // Remote-SSH disconnects. Scan the remote process list (not just terminal
  // output) for listening ports so they still auto-forward to localhost.
  "remote.autoForwardPortsSource": "process",
  "terminal.integrated.sendKeybindingsToShell": true,
  // Copilot commit message generation uses our commit convention instructions
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".github/instructions/commit-messages.instructions.md"
    }
  ],
  "sqltools.connections": [
    {
      "ssh": "Disabled",
      "previewLimit": 50,
      "server": "localhost",
      "port": 5432,
      "driver": "PostgreSQL",
      "name": "goat",
      "group": "GOAT",
      "database": "goat",
      "username": "rds",
      "password": "database_password"
    }
  ]
}