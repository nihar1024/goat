{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "uv-sync",
      "type": "shell",
      "command": "uv",
      "args": [
        "sync",
        "--all-packages"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "kill-port-8000",
      "type": "shell",
      "command": "kill $(ss -tlnp | grep ':8000 ' | grep -oP 'pid=\\K[0-9]+') 2>/dev/null || true",
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    },
    {
      "label": "kill-port-8100",
      "type": "shell",
      "command": "kill $(ss -tlnp | grep ':8100 ' | grep -oP 'pid=\\K[0-9]+') 2>/dev/null || true",
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    },
    {
